# ─────────────────────────────────────────────────
# Honeypot Threat Intelligence Platform
# Environment Variables Template
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# ── Threat Intelligence API Keys ─────────────────
# Shodan: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_key_here

# AbuseIPDB: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# VirusTotal: https://developers.virustotal.com/
VT_API_KEY=your_virustotal_key_here

# ── Elasticsearch Configuration ───────────────────
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=logstash-*
# Set username/password if ES security is enabled
# ELASTICSEARCH_USER=elastic
# ELASTICSEARCH_PASS=changeme

# ── GeoIP Database ────────────────────────────────
# Download from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEO_DB_PATH=./data/GeoLite2-City.mmdb

# ── STIX / TIP Feed Settings ─────────────────────
STIX_CAMPAIGN_NAME=honeypot-30day-2025
STIX_AUTHOR=ChandraVerse
STIX_OUTPUT_DIR=./tip-feed/stix-bundles/

# ── TAXII Server (optional) ───────────────────────
TAXII_HOST=0.0.0.0
TAXII_PORT=6000
TAXII_COLLECTION_ID=honeypot-ioc-feed

# ── Analysis Settings ─────────────────────────────
# How many days of data to analyse
ANALYSIS_DAYS=30
# Output directory for reports and figures
OUTPUT_DIR=./report/figures/
